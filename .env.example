# ==========================================================================
# 심리척도 설문·분석 플랫폼 환경 변수 예시
# 이 파일을 복사해 .env 로 만들고 실제 값을 채운다. (.env 는 커밋 금지)
# ==========================================================================

# --- 데이터베이스 (PostgreSQL / Supabase 권장) ---------------------------
# Supabase 사용 시: 프로젝트 > Settings > Database 에서 연결 문자열 복사.
# 애플리케이션 런타임(서버리스)에는 pgBouncer(6543, pooler) URL 사용을 권장.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Prisma migrate 는 direct 연결(5432)을 요구한다.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# 로컬 docker-compose 로 개발할 경우 예시:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psychology_survey?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/psychology_survey?schema=public"

# --- 세션 / 보안 ----------------------------------------------------------
# 세션 쿠키 서명용 비밀키 (아무 긴 랜덤 문자열). openssl rand -hex 32
# 세션 쿠키 HMAC 서명용 (프로덕션 필수). openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- 애플리케이션 --------------------------------------------------------
# 배포 시 실제 도메인. 설문 배포 URL / QR 코드 생성에 사용.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- 초기 관리자 계정 (seed 스크립트가 사용) -----------------------------
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin1234!"
